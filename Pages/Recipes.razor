@page "/recipes"
@using RecipeCost.Shared
@using System.Text.Json
@inject HttpClient Http
@inject JsonSerializerOptions JsonOptions

<h3>Recipe Manager</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h5>@(isEditing ? $"Editing {formModel.Name}" : "Create New Recipe")</h5>
        <EditForm Model="formModel" OnValidSubmit="HandleSave">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label>Recipe Name</label>
                    <InputText @bind-Value="formModel.Name" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Servings</label>
                    <InputNumber @bind-Value="formModel.Servings" class="form-control" />
                </div>
            </div>

            <h6>Ingredients</h6>
            <div class="row align-items-end mb-3">
                <div class="col-md-4">
                    <label>Select Ingredient</label>
                    <select class="form-control" @bind="selectedIngredientId">
                        <option value="0">-- Select --</option>
                        @foreach (var ing in availableIngredients)
                        {
                            <option value="@ing.Id">@ing.Name (@ing.BaseUnit)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Quantity</label>
                    <input type="number" class="form-control" @bind="tempQuantity" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-outline-success" @onclick="AddIngredientToRecipe">Add</button>
                </div>
            </div>

            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Ingredient</th>
                        <th>Qty</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in formModel.Ingredients)
                    {
                        <tr>
                            <td>@item.IngredientName</td>
                            <td>@item.Quantity</td>
                            <td>
                                <button type="button" class="btn btn-link text-danger" @onclick="() => formModel.Ingredients.Remove(item)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Recipe</button>
                @if (isEditing)
                {
                    <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </EditForm>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Recipe Name</th>
            <th>Total Cost</th>
            <th>Cost/Serving</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var recipe in recipeList)
        {
            <tr>
                <td>@recipe.Name</td>
                <td>@($"${recipe.TotalCost:0.####}")</td>
                <td>@($"${recipe.CostPerServing:0.#######}")</td>
                <td>
                    <button class="btn btn-sm btn-info" @onclick="() => StartEdit(recipe)">Edit</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<RecipeDto> recipeList = new();
    private List<IngredientDto> availableIngredients = new();
    private RecipeFormModel formModel = new();

    private int selectedIngredientId;
    private decimal tempQuantity;
    private bool isEditing;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            recipeList = await Http.GetFromJsonAsync<List<RecipeDto>>("api/recipes", JsonOptions) ?? new();
            availableIngredients = await Http.GetFromJsonAsync<List<IngredientDto>>("api/ingredients", JsonOptions) ?? new();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
    }

    private void AddIngredientToRecipe()
    {
        var ing = availableIngredients.FirstOrDefault(i => i.Id == selectedIngredientId);
        if (ing != null && tempQuantity > 0)
        {
            formModel.Ingredients.Add(new RecipeIngredientFormModel
            {
                IngredientId = ing.Id,
                IngredientName = ing.Name,
                Quantity = tempQuantity
            });
            tempQuantity = 0;
        }
    }

    private async Task HandleSave()
    {
        if (isEditing)
            await Http.PutAsJsonAsync($"api/recipes/{formModel.Id}", formModel.ToDto());
        else
            await Http.PostAsJsonAsync("api/recipes", formModel.ToDto());

        formModel = new();
        isEditing = false;
        await LoadData();
    }

    private void StartEdit(RecipeDto dto)
    {
        isEditing = true;
        formModel = new RecipeFormModel
        {
            Id = dto.Id,
            Name = dto.Name,
            Description = dto.Description,
            Servings = dto.Servings,
            Ingredients = dto.Ingredients.Select(i => new RecipeIngredientFormModel
            {
                IngredientId = i.IngredientId,
                IngredientName = i.IngredientName,
                Quantity = i.Quantity
            }).ToList()
        };
    }

    private void CancelEdit() { formModel = new(); isEditing = false; }

    public class RecipeFormModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Servings { get; set; } = 1;

        // This is where we track ingredients being added to the recipe
        public List<RecipeIngredientFormModel> Ingredients { get; set; } = new();

        public RecipeDto ToDto() => new RecipeDto
        {
            Id = this.Id,
            Name = this.Name,
            Description = this.Description,
            Servings = this.Servings,
            Ingredients = this.Ingredients.Select(i => i.ToDto()).ToList()
        };
    }

    public class RecipeIngredientFormModel
    {
        public int IngredientId { get; set; }
        public string IngredientName { get; set; } = string.Empty;
        public decimal Quantity { get; set; }

        public RecipeIngredientDto ToDto() => new RecipeIngredientDto
        {
            IngredientId = this.IngredientId,
            IngredientName = this.IngredientName,
            Quantity = this.Quantity
        };
    }
}