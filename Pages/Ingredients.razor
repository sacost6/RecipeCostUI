@page "/ingredients"
@using RecipeCost.Shared
@inject IngredientService IngredientService

<h3>Ingredient Manager</h3>

<div class="card mb-4">
    <div class="card-body">
        <h5>Add New Ingredient</h5>
        <EditForm Model="newIngredient" OnValidSubmit="HandleSave">
            <div class="row">
                <div class="col">
                    <input @bind="newIngredient.Name" class="form-control" placeholder="Name" />
                </div>
                <div class="col">
                    <input @bind="newIngredient.CostPerBaseUnit" type="number" step="0.0001" class="form-control" placeholder="Cost ($)" />
                </div>
                <div class="col">
                    <input @bind="newIngredient.BaseUnit" class="form-control" placeholder="Base Unit" />
                </div>
                <div class="col">
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Cost/Unit</th>
            <th>Base Unit</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ingredientList)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.CostPerBaseUnit.ToString("0.####")</td>
                <td>@item.BaseUnit</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<IngredientDto> ingredientList = new();
    private IngredientDto newIngredient = new();

    protected override async Task OnInitializedAsync()
    {
        ingredientList = await IngredientService.GetIngredientsAsync();
    }

    private async Task HandleSave()
    {
        await IngredientService.CreateIngredientAsync(newIngredient);
         
        ingredientList = await IngredientService.GetIngredientsAsync();

        newIngredient = new(); 
    }
}